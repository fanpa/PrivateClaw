{
  "name": "privateclaw",
  "version": "0.10.2",
  "description": "A self-hosted AI agent CLI",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "privateclaw": "./dist/bin/privateclaw.js"
  },
  "scripts": {
    "dev": "tsx bin/privateclaw.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "chmod +x dist/bin/privateclaw.js",
    "setup": "pnpm build && pnpm link --global",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/ bin/"
  },
  "keywords": [
    "ai",
    "agent",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.61",
    "@ai-sdk/openai": "^3.0.50",
    "ai": "^6.0.146",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "marked": "^18.0.0",
    "marked-terminal": "^7.3.0",
    "ora": "^9.3.0",
    "puppeteer-core": "^24.40.0",
    "readline": "^1.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
