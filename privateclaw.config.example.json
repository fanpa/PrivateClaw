{
  "provider": {
    "type": "openai",
    "baseURL": "http://localhost:8080/v1",
    "apiKey": "your-api-key",
    "model": "gpt-4o"
  },
  "security": {
    "allowedDomains": ["localhost", "internal.corp.com"],
    "defaultHeaders": {
      "internal.corp.com": {
        "Authorization": "Bearer your-api-token"
      }
    }
  },
  "session": {
    "dbPath": "./privateclaw-sessions.db"
  }
}
